@model Group4_ReadingComicWeb.ViewModels.PublicProfileViewModel
@{
    ViewData["Title"] = $"{Model.User.Username}'s Wall";
    var avatarUrl = !string.IsNullOrEmpty(Model.User.AvatarUrl) 
        ? Model.User.AvatarUrl 
        : $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(Model.User.Username)}&background=6366f1&color=fff&size=160";
    
    // Placeholder cover image with a darker overlay feel
    var coverUrl = "https://images.unsplash.com/photo-1614850523296-d8c1af93d400?q=80&w=2070&auto=format&fit=crop";
    
    var currentStatus = Model.User.Status;
    var isOnline = currentStatus == Group4_ReadingComicWeb.Models.Enum.AccountStatus.Online;
    var isBanned = currentStatus == Group4_ReadingComicWeb.Models.Enum.AccountStatus.Banned;
    
    var statusClass = isBanned ? "banned" : (isOnline ? "online" : "offline");
    var statusDisplay = isBanned ? "Banned" : (isOnline ? "Online Now" : "Offline");
    var statusIcon = isBanned ? "fa-ban" : "fa-circle";
}

<style>
    :root {
        --profile-accent: #4F46E5;
        --profile-accent-glow: rgba(79, 70, 229, 0.4);
    }

    .public-profile-wrapper {
        min-height: 100vh;
        background-color: var(--bg-color);
        padding-bottom: 3rem;
    }

    /* Hero Section */
    .profile-hero {
        position: relative;
        height: 320px;
        width: 100%;
        overflow: hidden;
    }

    .profile-cover {
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: brightness(0.6) contrast(1.1);
    }

    .profile-hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, transparent, var(--bg-color));
    }

    .profile-header-content {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding-bottom: 2rem;
    }

    .profile-avatar-wrapper {
        display: flex;
        align-items: flex-end;
        gap: 2rem;
    }

    .profile-avatar-container {
        position: relative;
        width: 160px;
        height: 160px;
        border-radius: 24px;
        background: var(--surface-color);
        padding: 4px;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.5);
    }

    .profile-avatar-main {
        width: 100%;
        height: 100%;
        border-radius: 20px;
        object-fit: cover;
    }

    .status-indicator {
        position: absolute;
        bottom: -5px;
        right: -5px;
        width: 24px;
        height: 24px;
        border-radius: 50%;
        border: 4px solid var(--bg-color);
    }

    .status-indicator.online { background-color: #10B981; box-shadow: 0 0 15px rgba(16, 185, 129, 0.5); }
    .status-indicator.offline { background-color: #6B7280; }
    .status-indicator.banned { background-color: #EF4444; }

    .profile-header-info h1 {
        font-size: 2.5rem;
        font-weight: 800;
        color: white;
        margin-bottom: 0.5rem;
        text-shadow: 0 2px 4px rgba(0,0,0,0.3);
    }

    .profile-meta-row {
        display: flex;
        gap: 1.5rem;
        color: var(--text-secondary);
        font-size: 0.95rem;
    }

    .meta-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    /* Grid Layout */
    .profile-layout {
        display: grid;
        grid-template-columns: 320px 1fr;
        gap: 2rem;
        margin-top: 2rem;
    }

    /* Cards */
    .glass-card {
        background: var(--surface-color);
        border: 1px solid var(--border-color);
        border-radius: 1.25rem;
        padding: 1.5rem;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    .section-title {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: white;
    }

    .section-title i {
        color: var(--primary-color);
    }

    .profile-bio {
        color: var(--text-secondary);
        line-height: 1.6;
        font-size: 0.95rem;
        margin-bottom: 1.5rem;
    }

    .stats-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .stat-item {
        background: rgba(255, 255, 255, 0.03);
        padding: 1rem;
        border-radius: 0.75rem;
        text-align: center;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .stat-value {
        display: block;
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--primary-color);
    }

    .stat-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--text-muted);
    }

    /* Comic Grid */
    .comic-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 1.5rem;
    }

    .comic-card {
        background: var(--surface-color);
        border-radius: 1rem;
        overflow: hidden;
        border: 1px solid var(--border-color);
        transition: var(--transition);
        display: flex;
        flex-direction: column;
    }

    .comic-card:hover {
        transform: translateY(-5px);
        border-color: var(--primary-color);
        box-shadow: 0 10px 20px -5px rgba(0, 0, 0, 0.5);
    }

    .card-thumb {
        position: relative;
        aspect-ratio: 2/3;
        overflow: hidden;
    }

    .card-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .comic-card:hover .card-thumb img {
        transform: scale(1.05);
    }

    .card-info {
        padding: 1rem;
    }

    .card-title {
        font-weight: 600;
        font-size: 0.95rem;
        color: white;
        margin-bottom: 0.5rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .card-stats {
        display: flex;
        justify-content: space-between;
        font-size: 0.8rem;
        color: var(--text-secondary);
    }

    /* Pagination */
    .pagination-wrapper {
        margin-top: 3rem;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 1rem;
    }

    .nav-btn {
        padding: 0.5rem 1rem;
        background: var(--surface-color);
        border: 1px solid var(--border-color);
        border-radius: 0.5rem;
        color: var(--text-primary);
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .nav-btn:hover:not(.disabled) {
        background: var(--primary-color);
        border-color: var(--primary-color);
        color: white;
    }

    .nav-btn.disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .page-info {
        color: var(--text-secondary);
        font-size: 0.9rem;
    }

    @@media (max-width: 992px) {
        .profile-layout {
            grid-template-columns: 1fr;
        }
        .profile-avatar-wrapper {
            flex-direction: column;
            align-items: center;
            text-align: center;
            gap: 1rem;
        }
        .profile-avatar-container {
            width: 140px;
            height: 140px;
        }
        .profile-meta-row {
            justify-content: center;
        }
    }
</style>

<div class="public-profile-wrapper">
    <section class="profile-hero">
        <img src="@coverUrl" alt="Cover" class="profile-cover">
        <div class="profile-hero-overlay"></div>
        
        <div class="profile-header-content">
            <div class="container">
                <div class="profile-avatar-wrapper">
                    <div class="profile-avatar-container">
                        <img src="@avatarUrl" alt="@Model.User.Username" class="profile-avatar-main">
                        <div class="status-indicator @statusClass" title="@statusDisplay"></div>
                    </div>
                    
                    <div class="profile-header-info">
                        <h1>@Model.User.Username</h1>
                        <div class="profile-meta-row">
                            <div class="meta-item">
                                <i class="fa-solid fa-calendar-days text-primary"></i>
                                <span>Joined @Model.JoinedDate</span>
                            </div>
                            <div class="meta-item">
                                <i class="fa-solid @statusIcon @(isOnline ? "text-accent" : "")"></i>
                                <span>@statusDisplay</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="container">
        <div class="profile-layout">
            <!-- Sidebar -->
            <aside>
                <div class="glass-card">
                    <h3 class="section-title">
                        <i class="fa-solid fa-user"></i> About Me
                    </h3>
                    <p class="profile-bio">
                        @(string.IsNullOrEmpty(Model.User.Bio) ? "Silence is the sanctuary of a strong soul. This user hasn't added a bio yet." : Model.User.Bio)
                    </p>
                    
                    <div class="stats-container">
                        <div class="stat-item">
                            <span class="stat-value">@Model.TotalComicsCount</span>
                            <span class="stat-label">Comics</span>
                        </div>
                        <div class="stat-item">
                            <span class="stat-value">@Model.TotalViewsCount</span>
                            <span class="stat-label">Views</span>
                        </div>
                    </div>
                </div>
            </aside>

            <!-- Main -->
            <main>
                <div class="glass-card" style="min-height: 400px;">
                    <h3 class="section-title">
                        <i class="fa-solid fa-book-open"></i> Published Works
                    </h3>
                    
                    @if (Model.AuthoredComics != null && Model.AuthoredComics.Any())
                    {
                        <div class="comic-grid">
                            @foreach (var comic in Model.AuthoredComics)
                            {
                                <a href="@Url.Action("Detail", "Comic", new { id = comic.ComicId })" class="comic-card">
                                    <div class="card-thumb">
                                        <img src="@comic.CoverImage" alt="@comic.Title" onerror="this.src='/images/placeholder-comic.jpg'">
                                    </div>
                                    <div class="card-info">
                                        <div class="card-title">@comic.Title</div>
                                        <div class="card-stats">
                                            <span><i class="fa-solid fa-eye mr-1"></i> @comic.ViewCount</span>
                                            <span class="text-primary">@comic.Status</span>
                                        </div>
                                    </div>
                                </a>
                            }
                        </div>

                        @if (Model.TotalPages > 1)
                        {
                            <div class="pagination-wrapper">
                                <a href="@Url.Action("PublicProfile", new { id = Model.User.UserId, page = Model.CurrentPage - 1 })" 
                                   class="nav-btn @(!Model.HasPreviousPage ? "disabled" : "")">
                                    <i class="fa-solid fa-chevron-left"></i> Previous
                                </a>
                                
                                <div class="page-info">
                                    Page @Model.CurrentPage of @Model.TotalPages
                                </div>
                                
                                <a href="@Url.Action("PublicProfile", new { id = Model.User.UserId, page = Model.CurrentPage + 1 })" 
                                   class="nav-btn @(!Model.HasNextPage ? "disabled" : "")">
                                    Next <i class="fa-solid fa-chevron-right"></i>
                                </a>
                            </div>
                        }
                    }
                    else
                    {
                        <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 4rem 0; opacity: 0.5;">
                            <i class="fa-solid fa-ghost" style="font-size: 4rem; margin-bottom: 1.5rem;"></i>
                            <p>No published comics yet.</p>
                        </div>
                    }
                </div>
            </main>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Check if SignalR is available for real-time status
            if (typeof statusConnection !== 'undefined') {
                const profileUserId = @Model.User.UserId;
                const statusIndicator = document.querySelector('.status-indicator');
                const statusText = document.querySelector('.meta-item:nth-child(2) span');
                const statusIcon = document.querySelector('.meta-item:nth-child(2) i');

                statusConnection.on("UserStatusChanged", function(userId, status) {
                    if (userId === profileUserId) {
                        statusIndicator.classList.remove('online', 'offline', 'banned');
                        statusIndicator.classList.add(status.toLowerCase());
                        statusIndicator.title = status;
                        statusText.textContent = (status === 'Online') ? 'Online Now' : status;
                        
                        if (status === 'Online') {
                            statusIcon.className = "fa-solid fa-circle text-accent";
                        } else if (status === 'Banned') {
                            statusIcon.className = "fa-solid fa-ban text-danger";
                        } else {
                            statusIcon.className = "fa-solid fa-circle";
                        }
                    }
                });
            }
        });
    </script>
}

