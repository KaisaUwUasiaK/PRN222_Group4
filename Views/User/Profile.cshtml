@model Group4_ReadingComicWeb.ViewModels.ProfileUpdateViewModel
@{
    ViewData["Title"] = "Edit Profile";
}

@section Styles {
    <link rel="stylesheet" href="~/css/components/user-profile.css" asp-append-version="true" />
}

<main class="container profile-container">
    <div class="profile-card">
        <div class="profile-header">
            <div class="profile-avatar-wrapper">
                <div class="profile-avatar-frame">
                    <img id="avatarImage" src="@(string.IsNullOrWhiteSpace(Model.User.AvatarUrl) ? "https://ui-avatars.com/api/?name=" + Uri.EscapeDataString(Model.User.Username) + "&background=3B82F6&color=fff&size=130" : Model.User.AvatarUrl)" alt="@Model.User.Username's Profile" class="profile-avatar-lg">
                    <label for="avatarFile" class="avatar-upload-btn" title="Change avatar">
                        <i class="fa-solid fa-camera"></i>
                    </label>
                    <input type="file" id="avatarFile" class="avatar-upload-input" accept="image/jpeg,image/jpg,image/png,image/gif">
                </div>
            </div>
        </div>

        <div class="profile-body">
            <div class="profile-title">
                <h2>Edit Profile</h2>
                <p>Update your personal information and manage your account.</p>
            </div>

            <form asp-action="Profile" method="post" id="profileForm" novalidate>
                @Html.AntiForgeryToken()

                
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label" asp-for="Username">
                            <i class="fa-solid fa-user"></i> Display Name
                        </label>
                        <input asp-for="Username" class="form-input" placeholder="Enter your display name" />
                        <span asp-validation-for="Username" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label class="form-label">
                            <i class="fa-solid fa-envelope"></i> Email Address
                        </label>
                        <input type="email" class="form-input" value="@Model.User.Email" disabled />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="Bio">
                        <i class="fa-solid fa-pen-to-square"></i> Bio
                    </label>
                    <textarea asp-for="Bio" class="form-textarea" placeholder="Tell us a little bit about yourself..."></textarea>
                </div>

                <div class="security-card">
                    <div class="security-info">
                        <div class="security-icon">
                            <i class="fa-solid fa-shield-halved"></i>
                        </div>
                        <div class="security-text">
                            <h4>Password &amp; Security</h4>
                            <p>Update your password to keep your account secure</p>
                        </div>
                    </div>
                    <a href="@Url.Action("ChangePassword", "User")" class="btn btn-outline">
                        <i class="fa-solid fa-lock"></i>
                        Change Password
                    </a>
                </div>

                <div class="profile-actions">
                    <button type="button" class="btn btn-danger" id="deleteAccountBtn">
                        <i class="fa-solid fa-trash-can"></i> Delete Account
                    </button>
                    <div class="actions-right">
                        <a href="@Url.Action("Index", "Home")" class="btn btn-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary">
                            <i class="fa-solid fa-check"></i> Save Changes
                        </button>
                    </div>
                </div>
            </form>

            <!-- Hidden delete form (separate from profile form) -->
            <form asp-action="DeleteAccount" method="post" id="deleteForm" style="display: none;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="confirmText" id="deleteConfirmText" />
            </form>
        </div>
    </div>
</main>

<!-- ── Delete Account Modal ── -->
<div id="deleteModal" class="delete-modal-overlay">
    <div class="delete-modal-card">
        <!-- Icon -->
        <div class="delete-modal-icon">
            <i class="fa-solid fa-triangle-exclamation"></i>
        </div>

        <!-- Title & description -->
        <h2 class="delete-modal-title">Delete Account</h2>
        <p class="delete-modal-desc">
            This action is <strong style="color: #EF4444;">permanent and irreversible</strong>.
            All your data, comments, and settings will be permanently deleted.<br><br>
            To confirm, please type <strong style="color: var(--text-primary); font-family: monospace;">DELETE</strong> below.
        </p>

        <!-- Input -->
        <label class="delete-modal-label" for="deleteModalInput">Confirmation phrase</label>
        <input id="deleteModalInput" class="delete-modal-input" type="text"
               placeholder="DELETE" autocomplete="off" spellcheck="false" />
        <div id="deleteModalError" class="delete-modal-error"></div>

        <!-- Actions -->
        <div class="delete-modal-actions">
            <button type="button" id="deleteModalCancel" class="btn btn-secondary">
                Cancel
            </button>
            <button type="button" id="deleteModalConfirm" class="btn btn-danger">
                <i class="fa-solid fa-trash"></i> Confirm Deletion
            </button>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script src="~/js/components/user-profile.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            initUserProfile({
                uploadAvatarUrl: '@Url.Action("UploadAvatar", "User")'
            });
        });
    </script>
}
