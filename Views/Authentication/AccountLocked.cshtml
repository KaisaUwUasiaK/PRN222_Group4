@{
    ViewData["Title"] = "Account Locked";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Account Locked - ComicVerse</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@500;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/%40phosphor-icons/web"></script>

    <link rel="stylesheet" href="~/css/components/account-locked.css" asp-append-version="true">
</head>
<body class="auth-page">
    <div class="auth-container">
        <div class="auth-card" style="max-width: 440px;">

            <!-- Logo -->
            <a href="@Url.Action("Index", "Home")" class="auth-logo">
                <i class="ph-fill ph-book-open-text locked-logo-icon"></i>
                <span>ComicVerse</span>
            </a>

            <!-- Lock Icon -->
            <div class="locked-icon-wrap">
                <i class="ph-fill ph-lock-key locked-lock-icon"></i>
            </div>

            <h1 class="locked-title">Account Locked</h1>
            <p class="locked-subtitle">
                Your account has been suspended and you are unable to sign in at this time.
            </p>

            <!-- Info Box -->
            <div class="locked-info-box">
                <i class="ph ph-warning-circle"></i>
                <p>
                    This account has been <strong>banned</strong> by an administrator due to a violation of our
                    <a href="#" class="locked-tos-link">Terms of Service</a>.
                    If you believe this is a mistake, please contact our support team.
                </p>
            </div>

            <!-- Actions -->
            <div class="locked-actions">
                <a href="mailto:support@comicverse.com" class="btn btn-primary locked-btn-primary">
                    <i class="ph ph-envelope locked-btn-icon"></i>
                    Contact Support
                </a>
                <a href="@Url.Action("Login", "Authentication")" class="btn btn-ghost locked-btn-ghost">
                    <i class="ph ph-arrow-left locked-btn-icon"></i>
                    Back to Login
                </a>
            </div>

        </div>
    </div>
</body>
</html>
