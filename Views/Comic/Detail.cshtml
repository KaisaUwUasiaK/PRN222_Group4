@model Group4_ReadingComicWeb.Models.Comic

@{
    ViewData["Title"] = Model.Title;
    var isFavorited = ViewBag.IsFavorited as bool? ?? false;
    var paginatedComments = ViewBag.PaginatedComments as List<Group4_ReadingComicWeb.Models.Comment>;
    var totalCommentPages = ViewBag.TotalCommentPages as int? ?? 1;
    var currentCommentPage = ViewBag.CurrentCommentPage as int? ?? 1;
}

<main>
    <section class="detail-hero">
        <div class="container detail-container">
            <div class="detail-thumb">
                <img src="@Model.CoverImage" alt="@Model.Title">
            </div>
            <div class="detail-info">
                <h1>@Model.Title</h1>
                <div class="detail-meta">
                    By <a asp-controller="User" asp-action="PublicProfile" asp-route-id="@Model.AuthorId"
                          style="color: var(--primary-color); font-weight: 500; text-decoration: none; transition: 0.2s;"
                          onmouseover="this.style.opacity='0.8'"
                          onmouseout="this.style.opacity='1'">@(Model.Author?.Username ?? "Unknown")</a> •
                    @if (Model.ComicTags != null)
                    {
                        @foreach (var ct in Model.ComicTags)
                        {
                            <span>@ct.Tag?.TagName • </span>
                        }
                    }
                    <span>@Model.ViewCount Views</span>
                </div>
                <p class="detail-description">
                    @Model.Description
                </p>
                
                <form id="favForm" asp-controller="Comic" asp-action="ToggleFavorite" method="post"
                      style="display:none;">
                    <input type="hidden" name="comicId" value="@Model.ComicId" />
                </form>
                <a href="#" onclick="document.getElementById('favForm').submit(); return false;"
                       class="btn btn-fav @(isFavorited ? "active" : "")">
                    <i class="@(isFavorited ? "fa-solid" : "fa-regular") fa-heart"></i>
                    @(isFavorited ? "Favorited" : "Add to Favorites")
                </a>
                
                <div class="chapters-section">
                    <div class="section-header">
                        <h2>Chapters</h2>
                    </div>
                    <div class="chapters-list">
                        @if (Model.Chapters != null && Model.Chapters.Any())
                        {
                            @foreach (var chapter in Model.Chapters.OrderByDescending(c => c.ChapterNumber).Take(5))
                            {
                                <a asp-action="Read" asp-route-id="@chapter.ChapterId" class="chapter-item group">
                                    <div class="chapter-info">
                                        <span class="chapter-name">Chapter @chapter.ChapterNumber: @chapter.Title</span>
                                    </div>
                                    <span class="chapter-time">@chapter.CreatedAt.ToString("dd MMM, yyyy")</span>
                                </a>
                            }
                        }
                        else
                        {
                            <div class="text-center" style="padding: 40px; color: var(--text-muted);">
                                <p>No chapters available yet.</p>
                            </div>
                        }
                    </div>
                    @if (Model.Chapters != null && Model.Chapters.Count > 5)
                    {
                        <a href="javascript:void(0)" class="view-all-btn" id="openChaptersModal">
                            <i class="fa-solid fa-list-ul"></i> View all chapters
                        </a>
                    }
                </div>
            </div>
        </div>
    </section>

    <section class="comments-section">
        <div class="container">
            <div class="comments-header">
                <h2>User Comments (@(ViewBag.TotalComments ?? 0))</h2>
            </div>
            
            <div class="comments-list" id="detail-comments-container">
                @if (paginatedComments != null && paginatedComments.Any())
                {
                    @foreach (var comment in paginatedComments)
                    {
                        <div class="comment-card">
                            <div class="comment-header">
                                <a href="@Url.Action("PublicProfile", "User", new { id = comment.UserId })"
                                       style="display: flex;">
                                    <img src="@(string.IsNullOrEmpty(comment.User?.AvatarUrl) ? $"https://ui-avatars.com/api/?name={comment.User?.Username}&background=4F46E5&color=fff" : comment.User.AvatarUrl)"
                                         class="comment-avatar" alt="Avatar">
                                </a>
                                <div class="comment-author-info">
                                    <a href="@Url.Action("PublicProfile", "User", new { id = comment.UserId })"
                                       class="comment-author"
                                       style="text-decoration: none; color: inherit; transition: color 0.2s;"
                                       onmouseover="this.style.color='var(--primary-color)'"
                                       onmouseout="this.style.color='inherit'">@comment.User?.Username</a>
                                    <span class="comment-meta">
                                        @if (comment.Chapter != null)
                                        {
                                            <text>Chapter @comment.Chapter.ChapterNumber • </text>
                                        }
                                        @comment.CreatedAt.ToString("dd MMM, yyyy HH:mm")
                                    </span>
                                </div>
                                @if (User.Identity?.IsAuthenticated == true && (User.Identity.Name == comment.User?.Username ||
                                                                                                                                                                                                                                                        User.IsInRole("Admin") || User.IsInRole("Moderator")))
                                {
                                    <form asp-action="DeleteComment" method="post" style="margin-left: auto;">
                                        <input type="hidden" name="commentId" value="@comment.CommentId" />
                                        <input type="hidden" name="source" value="Detail" />
                                        <input type="hidden" name="comicId" value="@Model.ComicId" />
                                        <button type="submit" style="background:none; border:none; color: #F87171; cursor:pointer;"
                                                title="Delete comment">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                            <p class="comment-text">@comment.Content</p>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center" style="padding: 40px; color: var(--text-muted);">
                        <p>No comments yet.</p>
                    </div>
                }
            </div>

            @if (totalCommentPages > 1)
            {
                <div class="pagination">
                    @if (currentCommentPage > 1)
                    {
                        <a href="@Url.Action("Detail", new { id = Model.ComicId, commentPage = currentCommentPage - 1 })"
                           class="page-link"><i class="fa-solid fa-chevron-left"></i></a>
                    }
                    
                    @for (int i = 1; i <= totalCommentPages; i++)
                    {
                        if (i == 1 || i == totalCommentPages || (i >= currentCommentPage - 2 && i <= currentCommentPage + 2))
                        {
                            <a href="@Url.Action("Detail", new { id = Model.ComicId, commentPage = i })"
                               class="page-link @(i == currentCommentPage ? "active" : "")">@i</a>
                        }
                        else if (i == currentCommentPage - 3 || i == currentCommentPage + 3)
                        {
                            <span style="color: var(--text-muted); display: flex; align-items: center;">...</span>
                        }
                    }

                    @if (currentCommentPage < totalCommentPages)
                    {
                        <a href="@Url.Action("Detail", new { id = Model.ComicId, commentPage = currentCommentPage + 1 })"
                           class="page-link"><i class="fa-solid fa-chevron-right"></i></a>
                    }
                </div>
            }
        </div>
    </section>
</main>

<!-- Chapters Modal -->
<div id="chaptersModal" class="modal">
    <div class="modal-content">
        <span class="close-modal" id="closeChaptersModal">&times;</span>
        <div class="modal-header">
            <h2>All Chapters</h2>
        </div>
        <div class="modal-chapters-list">
            @if (Model.Chapters != null && Model.Chapters.Any())
            {
                @foreach (var chapter in Model.Chapters.OrderByDescending(c => c.ChapterNumber))
                {
                    <a asp-action="Read" asp-route-id="@chapter.ChapterId" class="chapter-item">
                        <span class="chapter-name">Chapter @chapter.ChapterNumber: @chapter.Title</span>
                        <span class="chapter-time">@chapter.CreatedAt.ToString("dd MMM, yyyy")</span>
                    </a>
                }
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const modal = document.getElementById("chaptersModal");
            const btn = document.getElementById("openChaptersModal");
            const span = document.getElementById("closeChaptersModal");

            if (btn && modal && span) {
                btn.onclick = function () {
                    modal.classList.add("show");
                    document.body.style.overflow = "hidden";
                }

                span.onclick = function () {
                    modal.classList.remove("show");
                    document.body.style.overflow = "auto";
                }

                window.onclick = function (event) {
                    if (event.target == modal) {
                        modal.classList.remove("show");
                        document.body.style.overflow = "auto";
                    }
                }
            }
        });
    </script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.0/signalr.min.js"></script>

    <script>
        window.detailConfig = {
            comicId: @Model.ComicId,
            currentUserId: '@(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "")'
        };
    </script>

    <script src="~/js/comic-detail-comment.js" asp-append-version="true"></script>
}