@model IEnumerable<Group4_ReadingComicWeb.Models.Comic>

@{
    ViewData["Title"] = "All Comics";
}

<main class="container" style="margin-top: 2rem; margin-bottom: 4rem;">
    <!-- Dedicated Search & Filter Section -->
    <div class="search-filter-wrapper" style="display: flex; align-items: center; justify-content: space-between; gap: 4px; margin-top: 1rem; margin-bottom: 2rem; width: 100%;">
        <div class="search-bar" style="display: flex; align-items: center; flex: 1; margin: 0; height: 46px; padding: 0 20px; border-radius: 99px; background: var(--surface-color); border: 1px solid var(--border-color); transition: all 0.3s ease; max-width: none !important;">
            <i class="fa-solid fa-magnifying-glass" style="font-size: 1rem; color: var(--text-muted); flex-shrink: 0;"></i>
            <input type="text" id="indexSearchInput" placeholder="Search for comics..." 
                   style="font-size: 0.95rem; width: 100%; height: 100%; background: transparent; border: none; outline: none; color: var(--text-primary); padding-left: 12px;"
                   onkeypress="handleSearchKeyPress(event)" 
                   value="@ViewBag.SearchTerm">
        </div>
        
        <button type="button" class="advanced-filter-btn bubble-btn @(ViewBag.FilterOpen == true ? "active" : "")" onclick="toggleFilterPanel()" id="advancedFilterBtn" style="height: 46px; flex-shrink: 0; background: rgba(255, 255, 255, 0.05); border: 1px solid var(--border-color); color: var(--text-primary); font-weight: 600; font-size: 14px; cursor: pointer; display: flex; align-items: center; gap: 8px; padding: 0 18px; border-radius: 99px; transition: var(--transition); position: relative; overflow: hidden;">
            <i class="ph-bold ph-sliders-horizontal" style="font-size: 1.2rem;"></i>
            Advanced filter
        </button>
    </div>

    <!-- Advanced Filter Panel (Dropdown) -->
    <div id="advancedFilterPanel" class="filter-panel" style="max-height: @(ViewBag.FilterOpen == true ? "1000px" : "0"); overflow: hidden; transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1); margin-bottom: 0;">
        <div style="padding: 16px 0 40px; margin-bottom: 1rem;">
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 32px;">
                <!-- Sort options -->
                <div>
                    <h4 style="margin-bottom: 16px; font-size: 14px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px;">Sort by</h4>
                    <div class="filter-group sort-group" style="display: flex; flex-wrap: wrap; gap: 10px;">
                        <button class="filter-tag bubble-btn @(ViewBag.SelectedSortBy == "Latest" ? "active" : "")" onclick="selectFilter(this, 'sort')">Latest</button>
                        <button class="filter-tag bubble-btn @(ViewBag.SelectedSortBy == "Newest" ? "active" : "")" onclick="selectFilter(this, 'sort')">Newest</button>
                    </div>
                </div>
                
                <!-- Publication Status -->
                <div>
                    <h4 style="margin-bottom: 16px; font-size: 14px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px;">Publication Status</h4>
                    <div class="filter-group status-group" style="display: flex; flex-wrap: wrap; gap: 10px;">
                        <button class="filter-tag bubble-btn @(ViewBag.SelectedStatus == "Ongoing" ? "active" : "")" onclick="selectFilter(this, 'status')">Ongoing</button>
                        <button class="filter-tag bubble-btn @(ViewBag.SelectedStatus == "Completed" ? "active" : "")" onclick="selectFilter(this, 'status')">Completed</button>
                    </div>
                </div>
            </div>
            
            <!-- Comic Tags -->
            <div style="margin-top: 32px; padding-top: 24px; border-top: 1px solid rgba(255, 255, 255, 0.05);">
                <h4 style="margin-bottom: 16px; font-size: 14px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px;">Comic tags</h4>
                <div class="filter-group tag-group" style="display: flex; flex-wrap: wrap; gap: 10px;">
                    @{
                        var allTags = ViewBag.AllTags as List<Group4_ReadingComicWeb.ViewModels.TagListItemViewModel> 
                                      ?? new List<Group4_ReadingComicWeb.ViewModels.TagListItemViewModel>();
                        var selectedTags = ViewBag.SelectedTags as List<string> ?? new List<string>();
                    }
                    @foreach (var tag in allTags)
                    {
                        <button class="filter-tag bubble-btn @(selectedTags.Contains(tag.TagName) ? "active" : "")" 
                                onclick="toggleTag(this)">@tag.TagName</button>
                    }
                </div>
            </div>

            <!-- Action Buttons -->
            <div style="margin-top: 32px; padding-top: 24px; border-top: 1px solid rgba(255, 255, 255, 0.05); display: flex; gap: 12px; flex-wrap: wrap; align-items: center;">
                <button type="button" class="btn-filter-action bubble-btn" onclick="resetFilters()" style="background: #F87171; color: white; border: none; padding: 10px 24px; border-radius: 99px; font-weight: 600; cursor: pointer; display: flex; align-items: center; gap: 8px; font-size: 14px; position: relative; overflow: hidden;">
                    <i class="ph-bold ph-arrow-counter-clockwise"></i> Reset filter
                </button>
                <button type="button" class="btn-filter-action bubble-btn" onclick="luckyMe()" style="background: #34D399; color: white; border: none; padding: 10px 24px; border-radius: 99px; font-weight: 600; cursor: pointer; display: flex; align-items: center; gap: 8px; font-size: 14px; position: relative; overflow: hidden;">
                    <i class="ph-bold ph-magic-wand"></i> I'm feeling lucky
                </button>
                <div style="flex-grow: 1;"></div>
                <button type="button" class="btn-filter-action bubble-btn" onclick="applySearch()" style="background: #3B82F6; color: white; border: none; padding: 10px 40px; border-radius: 99px; font-weight: 700; cursor: pointer; display: flex; align-items: center; gap: 8px; font-size: 15px; position: relative; overflow: hidden;">
                    <i class="ph-bold ph-magnifying-glass"></i> Search
                </button>
            </div>
        </div>
    </div>

    <style>
        .filter-tag {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--border-color);
            color: var(--text-secondary);
            padding: 8px 18px;
            border-radius: 99px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s ease;
            position: relative;
            overflow: hidden;
        }

        .filter-tag:hover {
            background: rgba(255, 255, 255, 0.08);
            color: #fff;
        }

        .filter-tag.active {
            border-color: var(--primary-color) !important;
            color: var(--primary-color) !important;
            background: rgba(79, 70, 229, 0.1) !important;
            box-shadow: 0 0 10px rgba(79, 70, 229, 0.2);
        }

        /* Ripple/Bubble Effect */
        .bubble-btn .ripple {
            position: absolute;
            background: rgba(255, 255, 255, 0.3);
            transform: translate(-50%, -50%);
            pointer-events: none;
            border-radius: 50%;
            animation: ripple-animation 0.6s linear;
        }

        @@keyframes ripple-animation {
            from {
                width: 0px;
                height: 0px;
                opacity: 0.5;
            }
            to {
                width: 500px;
                height: 500px;
                opacity: 0;
            }
        }

        .search-bar:focus-within {
            border-color: var(--primary-color) !important;
            box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1);
        }

        .advanced-filter-btn:hover {
            background: rgba(79, 70, 229, 0.1) !important;
            border-color: var(--primary-color) !important;
            color: var(--primary-color) !important;
        }

        .advanced-filter-btn.active {
            background: var(--primary-color) !important;
            color: #fff !important;
            border-color: var(--primary-color) !important;
        }

        .btn-filter-action {
            transition: all 0.3s ease;
        }

        .btn-filter-action:hover {
            transform: translateY(-2px);
            filter: brightness(1.1);
            box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);
        }
        
        /* Mobile adjustment */
        @@media (max-width: 768px) {
            .search-filter-wrapper {
                flex-direction: column;
                align-items: stretch;
            }
            .search-filter-wrapper .search-bar {
                display: flex !important;
                max-width: 100% !important;
            }
            .advanced-filter-btn {
                width: 100%;
                justify-content: center;
            }
        }
    </style>

    <div class="section-header"
         style="margin-bottom: 2rem; border-bottom: 1px solid var(--border-color); padding-bottom: 1rem;">
        <div>
            <h2 style="font-size: 2rem; font-weight: 700;">
                @(string.IsNullOrEmpty(ViewBag.SearchTerm) ? "All Comics" : $"Search Results for \"{ViewBag.SearchTerm}\"")
            </h2>
            <p class="text-muted">
                @(string.IsNullOrEmpty(ViewBag.SearchTerm) ? "Discover the most complete comic book collection." :
                $"Found {Model.Count()} results matching your search.")
            </p>
        </div>

        <div class="flex gap-2">
            <span class="tag">Total: @Model.Count()</span>
        </div>
    </div>

    <div class="comic-grid">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <a href="@Url.Action("Detail", "Comic", new { id = item.ComicId })" class="comic-card"
                       style="display: block; color: inherit; text-decoration: none;">
                    <div class="card-image-wrapper">
                        <img src="@item.CoverImage" class="card-image" alt="@item.Title"
                             onerror="this.src='/images/default-cover.jpg'">
                    </div>
                    <h3 class="card-title" style="margin-top: 10px; font-size: 1.1rem; font-weight: 600;">@item.Title</h3>
                    <div class="flex justify-between items-center" style="margin-top: 5px;">
                        <p class="card-meta" style="color: var(--text-secondary); font-size: 0.9rem;">@item.Status</p>
                        @{
                            var latestChapter = item.Chapters?.OrderByDescending(c => c.ChapterNumber).FirstOrDefault();
                            var randomTag = item.ComicTags?.OrderBy(x => Guid.NewGuid()).FirstOrDefault();
                        }
                        @if (latestChapter != null)
                        {
                            <p style="color: var(--text-secondary); font-size: 0.85rem;">Chapter
                                @latestChapter.ChapterNumber</p>
                            }
                            else
                            {
                                <p style="color: var(--text-secondary); font-size: 0.85rem;">No chapters yet</p>
                            }
                            @if (randomTag != null)
                            {
                                <span
                                    style="font-size: 0.7rem; padding: 2px 8px; background: rgba(255,255,255,0.1); border-radius: 4px;">
                                    @randomTag.Tag.TagName
                                </span>
                            }
                        </div>
                    </a>
                }
            }
        else
            {
                <div style="grid-column: 1/-1; text-align: center; padding: 4rem;">
                    <i class="ph-bold ph-magnifying-glass" style="font-size: 3rem; color: var(--text-muted);"></i>
                    <p style="margin-top: 1rem;">
                        There are currently no comicss on the list.
                    </p>
                    <a href="/" class="btn btn-primary" style="margin-top: 1rem;">Back to home</a>
                </div>
            }
        </div>
        @if (ViewBag.TotalPages > 1)
        {
            <div class="pagination-container" style="display: flex; justify-content: center; margin-top: 3rem; gap: 8px;">

                @if (ViewBag.CurrentPage > 1)
                {
                    <a href="@Url.Action("Index", new { page = ViewBag.CurrentPage - 1, search = ViewBag.SearchTerm })"
                       class="btn-page">« Prev</a>
                }

                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <a href="@Url.Action("Index", new { page = i, search = ViewBag.SearchTerm })"
                           class="btn-page @(ViewBag.CurrentPage == i ? "active" : "")">
                        @i
                    </a>
                }

                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <a href="@Url.Action("Index", new { page = ViewBag.CurrentPage + 1, search = ViewBag.SearchTerm })"
                       class="btn-page">Next »</a>
                }
            </div>
        }

        <style>
                .btn-page {
                    padding: 8px 16px;
                    border: 1px solid #ddd;
                    border-radius: 4px;
                    color: white;
                    text-decoration: none;
                    background: rgba(255, 255, 255, 0.05);
                }

                .btn-page.active {
                    background: #e74c3c;
                    /* Màu thương hiệu của bạn */
                    border-color: #e74c3c;
                }

                .btn-page:hover:not(.active) {
                    background: rgba(255, 255, 255, 0.15);
                }
        </style>
    </main>
@section Scripts {
    <script>
        function toggleFilterPanel() {
            const panel = document.getElementById('advancedFilterPanel');
            const btn = document.getElementById('advancedFilterBtn');
            
            if (panel.style.maxHeight === '0px' || panel.style.maxHeight === '0') {
                panel.style.maxHeight = '1000px'; 
                btn.classList.add('active');
            } else {
                panel.style.maxHeight = '0';
                btn.classList.remove('active');
            }
        }

        function selectFilter(el, type) {
            const group = el.closest('.filter-group');
            group.querySelectorAll('.filter-tag').forEach(tag => tag.classList.remove('active'));
            el.classList.add('active');
        }

        function toggleTag(el) {
            el.classList.toggle('active');
        }

        function resetFilters() {
            document.querySelectorAll('.filter-tag').forEach(tag => tag.classList.remove('active'));
        }

        function getFilterData() {
            const searchInput = document.getElementById('indexSearchInput');
            const search = searchInput ? searchInput.value.trim() : "";
            const status = document.querySelector('.status-group .filter-tag.active')?.innerText || "";
            const sortBy = document.querySelector('.sort-group .filter-tag.active')?.innerText || "";
            const tags = Array.from(document.querySelectorAll('.tag-group .filter-tag.active')).map(t => t.innerText.trim());
            
            return { search, status, sortBy, tags };
        }

        function applySearch() {
            const data = getFilterData();
            const panel = document.getElementById('advancedFilterPanel');
            const isPanelOpen = panel.style.maxHeight !== '0px' && panel.style.maxHeight !== '0' && panel.style.maxHeight !== '';
            
            let query = `search=${encodeURIComponent(data.search)}&status=${encodeURIComponent(data.status)}&sortBy=${encodeURIComponent(data.sortBy)}&filterOpen=${isPanelOpen}`;
            data.tags.forEach(t => query += `&tags=${encodeURIComponent(t)}`);
            window.location.href = `/Comic/Index?${query}`;
        }

        function luckyMe() {
            const data = getFilterData();
            let query = `search=${encodeURIComponent(data.search)}&status=${encodeURIComponent(data.status)}`;
            data.tags.forEach(t => query += `&tags=${encodeURIComponent(t)}`);
            window.location.href = `/Comic/Lucky?${query}`;
        }

        // Ripple Effect Logic
        document.addEventListener('click', function (e) {
            const target = e.target.closest('.bubble-btn');
            if (target) {
                const ripple = document.createElement('span');
                ripple.classList.add('ripple');
                
                const rect = target.getBoundingClientRect();
                const size = Math.max(rect.width, rect.height);
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                
                ripple.style.width = ripple.style.height = size + 'px';
                ripple.style.left = x + 'px';
                ripple.style.top = y + 'px';
                
                target.appendChild(ripple);
                
                setTimeout(() => {
                    ripple.remove();
                }, 600);
            }
        });
    </script>
}