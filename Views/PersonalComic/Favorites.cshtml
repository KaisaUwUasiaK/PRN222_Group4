@model List<Group4_ReadingComicWeb.Models.Comic>
@{
    ViewData["Title"] = "My Favorites";
}

<main>
    <section class="comic-section" style="padding-top: 60px; min-height: 80vh;">
        <div class="container">
            <div class="section-header" style="margin-bottom: 40px; border-left: 4px solid var(--primary-color); padding-left: 20px;">
                <div>
                    <h2 style="font-size: 32px; font-weight: 800; margin-bottom: 4px;">My Library</h2>
                    <p style="color: var(--text-secondary); font-size: 14px;">Total: @Model.Count favorite comics</p>
                </div>
            </div>

            @if (Model != null && Model.Any())
            {
                <div class="comic-grid">
                    @foreach (var comic in Model)
                    {
                        <div class="comic-card" style="position: relative;">
                            <form asp-controller="PersonalComic" asp-action="RemoveFavorite" method="post" 
                                  style="position: absolute; top: 12px; right: 12px; z-index: 10; margin: 0;">
                                <input type="hidden" name="comicId" value="@comic.ComicId" />
                                <button type="submit" 
                                        onclick="return confirm('Remove @comic.Title from favorites?');"
                                        style="width: 32px; height: 32px; border-radius: 50%; background: rgba(239, 68, 68, 0.9); border: none; color: white; cursor: pointer; display: flex; align-items: center; justify-content: center; opacity: 0; transition: var(--transition); box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);"
                                        class="remove-btn"
                                        title="Remove from favorites">
                                    <i class="fa-solid fa-xmark"></i>
                                </button>
                            </form>

                            <a asp-controller="Comic" asp-action="Detail" asp-route-id="@comic.ComicId" class="comic-thumb" style="display: block;">
                                <img src="@comic.CoverImage" alt="@comic.Title">
                                @if (comic.Status?.ToLower() == "completed")
                                {
                                    <span style="position: absolute; bottom: 8px; right: 8px; background: #10B981; color: white; font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 4px; text-transform: uppercase;">Done</span>
                                }
                            </a>
                            <div class="comic-info">
                                <h3><a asp-controller="Comic" asp-action="Detail" asp-route-id="@comic.ComicId">@comic.Title</a></h3>
                                <p><i class="fa-regular fa-eye"></i> @comic.ViewCount Views</p>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div style="text-align: center; padding: 100px 20px; background: var(--surface-color); border-radius: 24px; border: 1px dashed var(--border-color);">
                    <div style="width: 80px; height: 80px; background: rgba(79, 70, 229, 0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 24px;">
                        <i class="fa-regular fa-heart" style="font-size: 32px; color: var(--primary-color); opacity: 0.5;"></i>
                    </div>
                    <h2 style="font-size: 24px; font-weight: 700; margin-bottom: 12px;">No favorites yet</h2>
                    <p style="color: var(--text-secondary); margin-bottom: 32px; max-width: 400px; margin-left: auto; margin-right: auto;">
                        Start exploring our vast collection of comics and save your favorites to access them easily anytime!
                    </p>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                        Find Comics to Read
                    </a>
                </div>
            }
        </div>
    </section>
</main>

<style>
    .comic-card:hover .remove-btn {
        opacity: 1;
        transform: scale(1.1);
    }
    .remove-btn:hover {
        background: #DC2626 !important;
        transform: scale(1.2) !important;
    }
</style>