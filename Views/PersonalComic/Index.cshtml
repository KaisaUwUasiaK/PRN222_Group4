@model IEnumerable< Group4_ReadingComicWeb.Models.Comic>

@{
    ViewData["Title"] = "My Comics";
}

@section Styles {
    <link rel="stylesheet" href="~/css/components/personal-comic-index.css" asp-append-version="true" />
}

<div class="container" style="margin-top: 3rem; min-height: 80vh;">
    <div class="page-header">
        <div class="page-title">
            <h2>Comic Management</h2>
            <p>Manage your uploaded comics, check their statuses, and add chapters.</p>
        </div>
        <a href="@Url.Action("Create")" class="btn btn-primary">
            <i class="fa-solid fa-cloud-arrow-up"></i> Upload Comic
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">
                <i class="fa-solid fa-book-open"></i>
            </div>
            <h3>You haven't uploaded any comics</h3>
            <p>Start your journey as an author by sharing your first comic with the world!</p>
            <a href="@Url.Action("Create")" class="btn btn-primary" style="padding: 12px 24px;">
                <i class="fa-solid fa-plus"></i> Upload Your First Comic
            </a>
        </div>
    }
    else
    {
        <div class="comic-list">
            @foreach (var item in Model)
            {
                <div class="comic-card-horizontal">
                    <div class="comic-cover">
                        <img src="@(string.IsNullOrEmpty(item.CoverImage) ? "https://via.placeholder.com/150x200?text=No+Cover" : item.CoverImage)"
                             alt="@item.Title"
                             onerror="this.src='https://via.placeholder.com/150x200?text=No+Cover'">
                    </div>

                    <div class="comic-details">
                        <div class="comic-header">
                            <h3 class="comic-title" title="@item.Title">@item.Title</h3>

                            @{
                                string statusClass = "status-canceled";
                                string statusText = item.Status;

                                if (item.Status == "Pending") 
                                { 
                                    statusClass = "status-pending"; 
                                    statusText = "Pending"; 
                                }
                                else if (item.Status == "OnWorking") 
                                { 
                                    statusClass = "status-working"; 
                                    statusText = "Ongoing"; 
                                }
                                else if (item.Status == "Completed") 
                                { 
                                    statusClass = "status-completed"; 
                                    statusText = "Completed"; 
                                }
                                else if (item.Status == "Rejected") 
                                { 
                                    statusClass = "status-rejected"; 
                                    statusText = "Rejected"; 
                                }
                                else if (item.Status == "Canceled") 
                                { 
                                    statusClass = "status-canceled"; 
                                    statusText = "Canceled"; 
                                }
                            }

                            <span class="status-badge @statusClass">
                                <span class="status-dot"></span>
                                @statusText
                            </span>
                        </div>
                        
                        <p class="comic-desc">@(string.IsNullOrWhiteSpace(item.Description) ? "No description provided." : item.Description)</p>

                        <div class="comic-stats">
                            <div class="stat-item" title="Published Date">
                                <i class="fa-solid fa-calendar-days"></i> @item.CreatedAt.ToString("MMM dd, yyyy")
                            </div>
                            <div class="stat-item" title="Total Chapters">
                                <i class="fa-solid fa-layer-group"></i> @(item.Chapters?.Count ?? 0) Chapters
                            </div>
                            <div class="stat-item highlight" title="Total Views">
                                <i class="fa-solid fa-eye"></i> @item.ViewCount.ToString("N0")
                            </div>
                        </div>

                        <div class="comic-actions">
                            <a href="@Url.Action("Chapters", new { id = item.ComicId })" class="btn btn-outline">
                                <i class="fa-solid fa-list"></i> Chapters
                            </a>
                           
                            @if (item.Status != "Canceled")
                            {
                                <a href="@Url.Action("Edit", new { id = item.ComicId })" class="btn btn-action">
                                    <i class="fa-solid fa-pen"></i> Edit
                                </a>
                            }

                            <form asp-action="Delete" asp-route-id="@item.ComicId" method="post" style="display:inline-block; margin: 0;">
                                @Html.AntiForgeryToken() 
                                @if (item.Status == "Pending")
                                {
                                    <button type="submit" class="btn btn-cancel-comic"
                                            onclick="return confirm('Are you sure you want to CANCEL this comic request? The status will be changed to Canceled.');">
                                        <i class="fa-solid fa-ban"></i> Cancel
                                    </button>
                                }
                                else if (item.Status == "OnWorking" || item.Status == "Completed" || item.Status == "Rejected" || item.Status == "Canceled")
                                {
                                    <button type="submit" class="btn btn-delete-comic"
                                            onclick="return confirm('WARNING: This action will PERMANENTLY DELETE the comic and all its chapters. This cannot be undone!');">
                                        <i class="fa-solid fa-trash-can"></i> Delete
                                    </button>
                                }
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
