@model Group4_ReadingComicWeb.Models.Chapter

@{
    ViewData["Title"] = "Read Chapter - " + Model.Title;
    var images = ViewBag.Images as List<string>;
}

@section Styles {
    <link rel="stylesheet" href="~/css/components/personal-comic-read.css" asp-append-version="true" />
}

<div class="reader-header">
    <div class="header-content">
        <div class="header-left">
            <a href="@Url.Action("Chapters", new { id = Model.ComicId })" class="btn-back" title="Back to Chapters">
                <i class="fa-solid fa-arrow-left"></i>
            </a>
            <div class="comic-info">
                <h4>@Model.Comic.Title</h4>
                <p>Chapter @Model.ChapterNumber: @Model.Title</p>
            </div>
        </div>

        <a href="@Url.Action("EditChapter", new { id = Model.ChapterId })" class="btn btn-outline modify-btn">
            <i class="fa-solid fa-pen-to-square"></i> Modify Chapter
        </a>
    </div>
</div>

<div class="reader-body">
    @if (images != null && images.Any())
    {
        <div class="image-container">
            @foreach (var imgPath in images)
            {
                <img src="@imgPath" alt="Comic Page" class="comic-page" loading="lazy" />
            }
        </div>
    }
    else
    {
        <div class="empty-reader">
            <i class="fa-solid fa-image"></i>
            <p><strong>Oh no!</strong> Cannot find any images for this chapter.</p>
            <p class="empty-reader-sub">They might have been deleted or did not upload correctly.</p>
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/components/auth-feedback.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
             initAuthFeedback({
                success: @Html.Raw(Json.Serialize(TempData["Success"] ?? TempData["SuccessMessage"])),
                error: @Html.Raw(Json.Serialize(TempData["Error"] ?? TempData["ErrorMessage"])),
                warning: @Html.Raw(Json.Serialize(TempData["Warning"])),
                info: @Html.Raw(Json.Serialize(TempData["Info"]))
            });
        });
    </script>
}