@model Group4_ReadingComicWeb.Models.Comic

@{
    ViewData["Title"] = "Modify Comic";
    var tags = ViewBag.Tags as List<Group4_ReadingComicWeb.Models.Tag>;
    var selectedTagIds = ViewBag.SelectedTagIds as List<int> ?? new List<int>();
}

@@section Styles {
    <link rel="stylesheet" href="~/css/components/personal-comic-form.css" asp-append-version="true" />
}

<div class="form-container">
    <a href="@Url.Action("Index")" class="back-link">
        <i class="fa-solid fa-arrow-left"></i> Back to My Comics
    </a>

    <div class="form-card">
        <div class="form-header">
            <h2><i class="fa-solid fa-pen-to-square" style="color: var(--primary-color); margin-right: 8px;"></i> Update Comic Information</h2>
            <p>Modify settings and details for <strong style="color: var(--text-primary);">@Model.Title</strong></p>
        </div>

        <form asp-action="Edit" asp-route-id="@Model.ComicId" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="ComicId" />

            <div asp-validation-summary="All" class="text-danger mb-4" style="color: #EF4444; font-size: 14px; margin-bottom: 20px;"></div>

            <div class="form-group">
                <label class="form-label" for="Title">
                    <i class="fa-solid fa-book"></i> Comic Title <span class="required-star">*</span>
                </label>
                <input asp-for="Title" name="Title" id="Title" class="form-control" placeholder="Enter comic name..." required />
            </div>

            <div class="form-group">
                <label class="form-label">
                    <i class="fa-solid fa-image"></i> Cover Image
                </label>
                <div class="cover-preview-container">
                    @if (!string.IsNullOrEmpty(Model.CoverImage))
                    {
                        <div class="cover-preview">
                            <img src="@Model.CoverImage" alt="Current Cover" onerror="this.src='https://via.placeholder.com/100x140?text=No+Cover'" />
                            <div class="cover-preview-overlay">Current</div>
                        </div>
                    }

                    <div class="file-input-wrapper">
                        <input type="file" name="coverImage" class="form-control" accept="image/*" />
                        <i class="fa-solid fa-upload file-input-icon"></i>
                        <p style="color: var(--text-muted); font-size: 13px; margin-top: 8px;">
                            Leave blank if you want to keep the original image.
                        </p>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" for="Description">
                    <i class="fa-solid fa-align-left"></i> Description
                </label>
                <textarea asp-for="Description" name="Description" id="Description" class="form-control" placeholder="Summarize the comic's story..." required></textarea>
            </div>

            <div class="form-group">
                <label class="form-label">
                    <i class="fa-solid fa-tags"></i> Tags
                </label>
                <div class="tags-container">
                    <div class="tags-grid">
                        @if (tags != null)
                        {
                            foreach (var tag in tags)
                            {
                                bool isChecked = selectedTagIds.Contains(tag.TagId);

                                <label class="tag-label">
                                    <input type="checkbox" class="tag-checkbox" name="selectedTags" value="@tag.TagId" @(isChecked ? "checked" : "") />
                                    <span class="tag-text">@tag.TagName</span>
                                </label>
                            }
                        }
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <a href="@Url.Action("Index")" class="btn btn-ghost">Cancel</a>
                <button type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-floppy-disk"></i> Save Changes
                </button>
            </div>
        </form>
    </div>
</div>