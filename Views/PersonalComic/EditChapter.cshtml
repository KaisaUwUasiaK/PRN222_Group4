@model Group4_ReadingComicWeb.Models.Chapter

@{
    ViewData["Title"] = "Modify Chapter";
}

@section Styles {
    <link rel="stylesheet" href="~/css/components/personal-comic-edit-chapter.css" asp-append-version="true" />
}

<div class="form-container">
    <a href="@Url.Action("Chapters", new { id = Model.ComicId })" class="back-link">
        <i class="fa-solid fa-arrow-left"></i> Back to Chapters
    </a>

    <div class="form-card">
        <div class="form-header">
            <h2><i class="fa-solid fa-pen-to-square header-icon"></i> Update Chapter</h2>
        </div>

        <form asp-action="EditChapter" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="ChapterId" />
            <input type="hidden" asp-for="ComicId" />
            <input type="hidden" name="id" value="@Model.ChapterId" />

            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label">
                        <i class="fa-solid fa-hashtag"></i> Chapter No.
                    </label>
                    <input asp-for="ChapterNumber" class="form-control" placeholder="E.g., 1" required />
                </div>
                <div class="form-group">
                    <label class="form-label">
                        <i class="fa-solid fa-heading"></i> Chapter Title
                    </label>
                    <input asp-for="Title" class="form-control" placeholder="Optional title..." />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">
                    <i class="fa-solid fa-images"></i> Content Files (Images)
                </label>
                <input type="file" name="newPages" id="fileInput" class="form-control"
                       multiple accept="image/*" />
                
                <p class="file-help-text">
                    Leave blank to keep the currently uploaded images.
                </p>

                <div class="warning-box">
                    <div class="warning-header">
                        <i class="fa-solid fa-circle-exclamation"></i>
                        <strong>Warning & Note</strong>
                    </div>

                    <p class="warning-text">
                        If you upload new images, the <strong>old images will be deleted</strong>. <br />
                        The system sorts images by <strong>file name</strong>. Ensure they are numbered correctly.
                    </p>

                    <div class="naming-guide">
                        <div class="naming-good">
                            <i class="fa-solid fa-circle-check"></i> 001.jpg, 002.jpg
                        </div>
                        <div class="divider"></div>
                        <div class="naming-bad">
                            <i class="fa-solid fa-circle-xmark"></i> page1.jpg, page2.jpg
                        </div>
                    </div>
                </div>

                <div id="fileListPreview" class="file-preview-container"></div>
            </div>

            <div class="form-actions">
                <a href="@Url.Action("Chapters", new { id = Model.ComicId })" class="btn btn-ghost">Cancel</a>
                <button type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-floppy-disk"></i> Save Chapter
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/components/auth-feedback.js" asp-append-version="true"></script>
    <script src="~/js/components/personal-comic-edit-chapter.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
             initAuthFeedback({
                success: @Html.Raw(Json.Serialize(TempData["Success"] ?? TempData["SuccessMessage"])),
                error: @Html.Raw(Json.Serialize(TempData["Error"] ?? TempData["ErrorMessage"])),
                warning: @Html.Raw(Json.Serialize(TempData["Warning"])),
                info: @Html.Raw(Json.Serialize(TempData["Info"]))
            });
            initEditChapter();
        });
    </script>
}