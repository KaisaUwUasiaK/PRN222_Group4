@model Group4_ReadingComicWeb.Models.Comic

@{
    ViewData["Title"] = "Chapter Management - " + Model.Title;
}

@section Styles {
    <link rel="stylesheet" href="~/css/components/personal-comic-chapters.css" asp-append-version="true" />
}

<div class="page-container">
    <a href="@Url.Action("Index")" class="back-link">
        <i class="fa-solid fa-arrow-left"></i> Back to My Comics / <span class="title-hl">@Model.Title</span>
    </a>

    <div class="layout-grid">
        <!-- Left Panel: Chapter List -->
        <div class="panel-card">
            <div class="panel-header">
                <h3><i class="fa-solid fa-list-ul header-icon"></i> Chapter List</h3>
                <span class="chapter-count">Total: @(Model.Chapters?.Count ?? 0)</span>
            </div>

            @if (Model.Chapters == null || !Model.Chapters.Any())
            {
                <div class="empty-state">
                    <i class="fa-solid fa-folder-open"></i>
                    <p>No chapters uploaded yet.</p>
                </div>
            }
            else
            {
                <div class="chapter-list">
                    @foreach (var chap in Model.Chapters.OrderByDescending(c => c.ChapterNumber))
                    {
                        <div class="chapter-item">
                            <div class="chapter-info">
                                <span class="chapter-number">Chapter @chap.ChapterNumber</span>
                                <span class="chapter-title">@chap.Title</span>
                                <span class="chapter-date"><i class="fa-regular fa-clock"></i> @chap.CreatedAt.ToString("MMM dd")</span>
                            </div>

                            <div class="chapter-actions">
                                <a href="@Url.Action("Read", new { id = chap.ChapterId })" class="btn-icon" title="Read Chapter">
                                    <i class="fa-solid fa-eye"></i>
                                </a>

                                <a href="@Url.Action("EditChapter", new { id = chap.ChapterId })" class="btn-icon" title="Edit Chapter">
                                    <i class="fa-solid fa-pen"></i>
                                </a>

                                <form asp-action="DeleteChapter" asp-route-id="@chap.ChapterId" method="post"
                                      onsubmit="return confirm('Are you sure you want to delete Chapter @chap.ChapterNumber? This will securely delete all images belonging to this chapter.');"
                                      style="display: inline; margin: 0;">
                                    <button type="submit" class="btn-icon delete" title="Delete Chapter">
                                        <i class="fa-solid fa-trash-can"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Right Panel: Upload Form -->
        <div class="sticky-col">
            <div class="panel-card">
                <div class="panel-header">
                    <h3><i class="fa-solid fa-cloud-arrow-up header-icon"></i> Upload New Chapter</h3>
                </div>

                <form asp-action="CreateChapter" method="post" enctype="multipart/form-data">
                    <input type="hidden" name="comicId" value="@Model.ComicId" />

                    <div class="upload-form-grid">
                        <div class="form-group">
                            <label class="form-label">Chapter No.</label>
                            <input type="number" name="chapterNumber" class="form-control" placeholder="E.g: 1" required />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Chapter Title</label>
                            <input type="text" name="title" class="form-control" placeholder="Optional title..." />
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Content (Multiple Images)</label>
                        <input type="file" name="pages" id="fileInput" class="form-control"
                               multiple accept="image/*" required />

                        <div class="warning-box">
                            <div class="warning-header">
                                <i class="fa-solid fa-circle-exclamation"></i>
                                <strong>Important Note</strong>
                            </div>

                            <p class="warning-text">
                                The system sorts images by <strong>file name</strong>. Ensure they are numbered correctly so pages appear in order.
                            </p>

                            <div class="naming-guide">
                                <div class="naming-good">
                                    <i class="fa-solid fa-circle-check"></i> 001.jpg, 002.jpg
                                </div>
                                <div class="divider"></div>
                                <div class="naming-bad">
                                    <i class="fa-solid fa-circle-xmark"></i> page1.jpg, ...
                                </div>
                            </div>
                        </div>

                        <div id="fileListPreview" class="file-list-preview"></div>
                    </div>

                    <button type="submit" class="btn btn-primary upload-btn">
                        <i class="fa-solid fa-upload"></i> Upload & Submit
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/components/auth-feedback.js" asp-append-version="true"></script>
    <script src="~/js/components/personal-comic-chapters.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
             initAuthFeedback({
                success: @Html.Raw(Json.Serialize(TempData["Success"] ?? TempData["SuccessMessage"])),
                error: @Html.Raw(Json.Serialize(TempData["Error"] ?? TempData["ErrorMessage"])),
                warning: @Html.Raw(Json.Serialize(TempData["Warning"])),
                info: @Html.Raw(Json.Serialize(TempData["Info"]))
            });
            initChapterManagement();
        });
    </script>
}