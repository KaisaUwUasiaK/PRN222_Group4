@model Group4_ReadingComicWeb.Models.Tag

@{
    ViewData["Title"] = "Create Tag";
    ViewData["Breadcrumb"] = "Create Tag";
    Layout = "~/Views/Shared/_ModeratorLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/components/tag-create.css" asp-append-version="true" />
}

<div class="container tag-create-container">
    <div class="page-header tag-create-header">
        <div class="page-header-left">
            <h1>Create Tag</h1>
            <p>Add a new comic tag.</p>
        </div>
    </div>

    <div class="data-card tag-create-card">
        <form asp-action="Create" asp-controller="Tag" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="form-group tag-create-form-group">
                <label asp-for="TagName" class="form-label">Tag Name</label>
                <input asp-for="TagName" class="search-input" maxlength="100" placeholder="e.g. Action, Romance, Fantasy" />
                <span asp-validation-for="TagName" class="text-danger"></span>
            </div>

            <div class="tag-create-actions">
                <a href="@Url.Action("Index", "Tag")" class="btn btn-ghost tag-create-cancel-btn">Cancel</a>
                <button type="submit" class="btn btn-primary">
                    <i class="ph ph-floppy-disk"></i> Save Tag
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script src="~/js/components/auth-feedback.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
             initAuthFeedback({
                success: @Html.Raw(Json.Serialize(TempData["Success"] ?? TempData["SuccessMessage"])),
                error: @Html.Raw(Json.Serialize(TempData["Error"] ?? TempData["ErrorMessage"])),
                warning: @Html.Raw(Json.Serialize(TempData["Warning"])),
                info: @Html.Raw(Json.Serialize(TempData["Info"]))
            });
        });
    </script>
}