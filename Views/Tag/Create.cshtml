@model Group4_ReadingComicWeb.Models.Tag

@{
    ViewData["Title"] = "Create Tag";
    ViewData["Breadcrumb"] = "Create Tag";
    Layout = "~/Views/Shared/_ModeratorLayout.cshtml";
}

<div class="container" style="max-width: 720px;">
    <div class="page-header" style="margin-bottom: 1.25rem;">
        <div class="page-header-left">
            <h1>Create Tag</h1>
            <p>Add a new comic tag.</p>
        </div>
    </div>

    <div class="data-card" style="padding: 1.25rem;">
        <form asp-action="Create" asp-controller="Tag" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="form-group" style="margin-bottom: 1rem;">
                <label asp-for="TagName" class="form-label">Tag Name</label>
                <input asp-for="TagName" class="search-input" maxlength="100" placeholder="e.g. Action, Romance, Fantasy" />
                <span asp-validation-for="TagName" class="text-danger"></span>
            </div>

            <div style="display: flex; gap: 10px; margin-top: 1.25rem;">
                <a href="@Url.Action("Index", "Tag")" class="btn btn-ghost" style="border: 1px solid var(--border-color);">Cancel</a>
                <button type="submit" class="btn btn-primary">
                    <i class="ph ph-floppy-disk"></i> Save Tag
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}