@model Group4_ReadingComicWeb.Models.Tag

@{
    ViewData["Title"] = "Edit Tag";
    ViewData["Breadcrumb"] = "Edit Tag";
    Layout = "~/Views/Shared/_ModeratorLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/components/tag-edit.css" asp-append-version="true" />
}

<div class="container tag-edit-container">
    <div class="page-header tag-edit-header">
        <div class="page-header-left">
            <h1>Edit Tag</h1>
            <p>Update tag information.</p>
        </div>
    </div>

    <div class="data-card tag-edit-card">
        <form id="editTagForm" asp-action="Edit" asp-controller="Tag" asp-route-id="@Model.TagId" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="TagId" />
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="form-group tag-edit-form-group">
                <label asp-for="TagName" class="form-label">Tag Name</label>
                <input asp-for="TagName" class="search-input" maxlength="100" />
                <span asp-validation-for="TagName" class="text-danger"></span>
            </div>

            <div class="tag-edit-actions">
                <a href="@Url.Action("Index", "Tag")" class="btn btn-ghost tag-edit-cancel-btn">Cancel</a>
                <button type="button" id="saveTagBtn" class="btn btn-primary">
                    <i class="ph ph-check"></i> Update Tag
                </button>
            </div>
        </form>
    </div>
</div>

<div id="editConfirmModal" class="modal-overlay">
    <div class="modal-card tag-edit-modal-card">
        <div class="modal-header">
            <h2 class="modal-title">Confirm Update</h2>
            <button class="modal-close" type="button" id="editConfirmCloseBtn">
                <i class="ph ph-x"></i>
            </button>
        </div>

        <div class="tag-edit-modal-body">
            <p class="tag-edit-modal-text">
                Save changes for this tag? Please make sure the name is correct before continuing.
            </p>
        </div>

        <div class="tag-edit-modal-footer">
            <button type="button" class="btn btn-ghost tag-edit-modal-cancel-btn" id="editConfirmCancelBtn">Cancel</button>
            <button type="button" class="btn btn-primary" id="editConfirmOkBtn">Save Changes</button>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script src="~/js/components/tag-edit.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            initTagEdit();
        });
    </script>
}