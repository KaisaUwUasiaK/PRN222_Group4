@{
    ViewData["Title"] = "Dashboard";
    ViewData["Breadcrumb"] = "Dashboard";
    Layout = "_AdminLayout";
}

<!-- Page Header -->
<div class="page-header">
    <div class="page-header-left">
        <h1>Dashboard</h1>
        <p>Welcome back, @User.Identity?.Name. Here's what's happening today.</p>
    </div>
</div>

<!-- Stats Grid -->
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon stat-icon-purple">
            <i class="ph ph-books"></i>
        </div>
        <div class="stat-label">Total Comics</div>
        <div class="stat-value">1,240</div>
        <div class="stat-trend up">
            <i class="ph ph-trend-up"></i> +12 this week
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon stat-icon-green">
            <i class="ph ph-users"></i>
        </div>
        <div class="stat-label">Total Users</div>
        <div class="stat-value">54,302</div>
        <div class="stat-trend up">
            <i class="ph ph-trend-up"></i> +1.2k this week
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon stat-icon-blue">
            <i class="ph ph-eye"></i>
        </div>
        <div class="stat-label">Daily Views</div>
        <div class="stat-value">89.4k</div>
        <div class="stat-trend down">
            <i class="ph ph-trend-down"></i> -3% from yesterday
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon stat-icon-red">
            <i class="ph ph-clock-countdown"></i>
        </div>
        <div class="stat-label">Pending Uploads</div>
        <div class="stat-value">8</div>
        <div class="stat-trend neutral">
            <i class="ph ph-minus"></i> Needs review
        </div>
    </div>
</div>

<!-- Recent Upload Requests -->
<div class="data-card">
    <div class="data-card-header">
        <h3 class="data-card-title">Recent Upload Requests</h3>
        <button class="btn btn-outline" style="padding: 6px 14px; font-size: 0.85rem;">View All</button>
    </div>
    <div style="overflow-x: auto;">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Comic</th>
                    <th>Author</th>
                    <th>Genre</th>
                    <th>Status</th>
                    <th>Date</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td style="font-weight: 600; color: var(--text-primary);">The Return of the Hero</td>
                    <td>User_123</td>
                    <td>Action</td>
                    <td><span class="badge badge-warning"><span class="badge-dot" style="background: #FBBF24;"></span>Pending</span></td>
                    <td>Feb 18, 2026</td>
                    <td><button class="action-btn" style="color: var(--color-primary); border-color: rgba(124,58,237,0.3);">Review</button></td>
                </tr>
                <tr>
                    <td style="font-weight: 600; color: var(--text-primary);">My Life as a Slime</td>
                    <td>SlimeLover</td>
                    <td>Fantasy</td>
                    <td><span class="badge badge-success"><span class="badge-dot" style="background: #34D399;"></span>Approved</span></td>
                    <td>Feb 17, 2026</td>
                    <td><button class="action-btn" style="color: var(--text-muted); border-color: var(--border-color);">Edit</button></td>
                </tr>
                <tr>
                    <td style="font-weight: 600; color: var(--text-primary);">Dark Souls: The Comic</td>
                    <td>FromFan</td>
                    <td>Horror</td>
                    <td><span class="badge badge-danger"><span class="badge-dot" style="background: #FB7185;"></span>Rejected</span></td>
                    <td>Feb 16, 2026</td>
                    <td><button class="action-btn" style="color: var(--text-muted); border-color: var(--border-color);">Details</button></td>
                </tr>
                <tr>
                    <td style="font-weight: 600; color: var(--text-primary);">Cyberpunk 2099</td>
                    <td>NeonCity</td>
                    <td>Sci-Fi</td>
                    <td><span class="badge badge-warning"><span class="badge-dot" style="background: #FBBF24;"></span>Pending</span></td>
                    <td>Feb 16, 2026</td>
                    <td><button class="action-btn" style="color: var(--color-primary); border-color: rgba(124,58,237,0.3);">Review</button></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
<div class="data-card" style="margin-top: 2rem;">
    <div class="data-card-header">
        <div class="d-flex align-items-center" style="gap: 10px;">
            <h3 class="data-card-title">System Activities</h3>
            <span class="badge badge-success" style="font-size: 0.7rem; padding: 2px 8px;">
                <span class="badge-dot" style="background: #34D399; animation: pulse 2s infinite;"></span>Live
            </span>
        </div>
        <a href="@Url.Action("Index", "AdminLog")" class="btn btn-outline" style="padding: 6px 14px; font-size: 0.85rem; text-decoration: none;">View All Logs</a>
    </div>
    <div style="overflow-x: auto;">
        @* Giả sử bạn truyền 5 log mới nhất qua ViewBag.RecentLogs *@
        @await Html.PartialAsync("~/Views/AdminLog/_LogTablePartial.cshtml", (IEnumerable<Group4_ReadingComicWeb.Models.Log>)ViewBag.RecentLogs)
    </div>
</div>

<style>
    @@keyframes pulse {
        0% {
            opacity: 1;
        }

        50% {
            opacity: 0.3;
        }

        100% {
            opacity: 1;
        }
    }

    .new-log-row {
        animation: slideIn 0.5s ease-out;
        background: rgba(124, 58, 237, 0.05);
    }

    @@keyframes slideIn {
        from {
            transform: translateX(-10px);
            opacity: 0;
        }

        to {
            transform: translateX(0);
            opacity: 1;
        }
    }
</style>
<script>
    const logConnection = new signalR.HubConnectionBuilder()
        .withUrl("/logHub")
        .build();

    logConnection.on("ReceiveLog", function (log) {
        const tbody = document.querySelector("#logTableDashboard tbody");
        if (tbody) {
            const rowHtml = `
                <tr class="new-log-row">
                    <td style="font-weight: 600; color: var(--text-primary);">${log.username}</td>
                    <td>
                        <span class="badge" style="background: rgba(124, 58, 237, 0.1); color: var(--color-primary); padding: 4px 8px; border-radius: 4px; font-size: 0.8rem;">
                            ${log.action}
                        </span>
                    </td>
                    <td style="text-align: right; color: var(--text-muted); font-size: 0.85rem;">${log.time.split(' ')[1]}</td>
                </tr>
            `;
            // Chèn lên đầu
            tbody.insertAdjacentHTML('afterbegin', rowHtml);

            // Giữ lại tối đa 5 dòng cho đẹp Dashboard
            if (tbody.children.length > 5) {
                tbody.lastElementChild.remove();
            }
        }
    });

    logConnection.start().catch(err => console.error(err));
</script>