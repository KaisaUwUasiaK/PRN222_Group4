@using Group4_ReadingComicWeb.Models.Enum
@model List<Group4_ReadingComicWeb.Models.Report>

@{
    ViewData["Title"] = "Moderator Reports";
    ViewData["Breadcrumb"] = "Moderator Reports";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/components/report-list.css" asp-append-version="true" />
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Moderator Reports</h1>
        <p>Review and take action on reports submitted against moderators.</p>
    </div>
</div>

<div class="data-card">
    <div class="data-card-header">
        <h3 class="data-card-title">Pending Reports</h3>
        <span class="badge report-count-badge">
            @Model.Count
        </span>
    </div>

    @if (Model.Any())
    {
        <div style="overflow-x: auto;">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Reporter</th>
                        <th>Target Moderator</th>
                        <th>Type</th>
                        <th>Reason</th>
                        <th>Date</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var report in Model)
                    {
                        <tr>
                            <td class="report-reporter">@(report.Reporter?.Username ?? "Unknown")</td>
                            <td class="report-target-user">@(report.TargetUser?.Username ?? "Unknown")</td>
                            <td>
                                <span class="badge report-type-badge">
                                    @report.ReportType
                                </span>
                            </td>
                            <td>@report.Reason</td>
                            <td>@report.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td>
                                <a href="@Url.Action("Details", "Report", new { id = report.ReportId })"
                                   class="action-btn table-action-review">
                                    Review
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="ph ph-check-circle empty-state-icon"></i>
            <p class="empty-state-title">No pending reports!</p>
            <p class="empty-state-desc">All moderator reports have been reviewed.</p>
        </div>
    }
</div>