@{
    ViewData["Title"] = "Browse";
}

<main>
    <!-- Hero Section -->
    <section class="hero">
        <div class="container hero-container">
            <div class="hero-content">
                <span class="badge">TRENDING NOW</span>
                <h1>The Legend of the Northern Blade</h1>
                <div class="hero-meta">
                    <span>Action</span> • <span>Adventure</span> • <span>Fantasy</span> • <span>2.5M Views</span>
                </div>
                <p class="hero-description">
                    When the world was plunged into darkness, the Northern Heavenly Sect gathered to maintain the peace. But when the sect leader is betrayed...
                </p>
                <div class="hero-actions">
                    <a asp-action="Read" class="btn btn-primary">Read Now</a>
                    <a href="#" class="btn btn-secondary"><i class="fa-regular fa-heart"></i> Favorite</a>
                </div>
            </div>
            <div class="hero-image">
                <img src="~/assets/hero-comic.png" alt="The Legend of the Northern Blade">
            </div>
        </div>
    </section>

    <!-- Comic Sections -->
    <section class="comic-section">
        <div class="container">
            <div class="section-header">
                <h2>Latest Releases</h2>
                <a href="#" class="view-all">View All</a>
            </div>
            <div class="comic-grid">
                <div class="comic-card">
                    <a asp-action="Detail" class="comic-thumb">
                        <img src="~/assets/solo-leveling.png" alt="Solo Leveling">
                    </a>
                    <div class="comic-info">
                        <h3><a asp-action="Detail">Solo Leveling</a></h3>
                        <p>Chapter 179</p>
                    </div>
                </div>
                <div class="comic-card">
                    <div class="comic-thumb">
                        <img src="~/assets/oshino-ko.png" alt="Oshi no Ko">
                    </div>
                    <div class="comic-info">
                        <h3>Oshi no Ko</h3>
                        <p>Chapter 142</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="comic-section">
        <div class="container">
            <div class="section-header">
                <h2>Trending Comics</h2>
                <a href="#" class="view-all">View All</a>
            </div>
            <div class="comic-grid">
                <div class="comic-card">
                    <div class="comic-thumb">
                        <img src="~/assets/solo-leveling.png" alt="Solo Leveling">
                    </div>
                    <div class="comic-info">
                        <h3>Solo Leveling</h3>
                        <p>Chapter 179</p>
                    </div>
                </div>
                <div class="comic-card">
                    <div class="comic-thumb">
                        <img src="~/assets/oshino-ko.png" alt="Oshi no Ko">
                    </div>
                    <div class="comic-info">
                        <h3>Oshi no Ko</h3>
                        <p>Chapter 142</p>
                    </div>
                </div>
                <div class="comic-card">
                    <div class="comic-thumb">
                        <img src="~/assets/vagabond.png" alt="Vagabond">
                    </div>
                    <div class="comic-info">
                        <h3>Vagabond</h3>
                        <p>Chapter 327</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="comic-section">
        <div class="container">
            <div class="section-header">
                <h2>Maybe you like!</h2>
                <a href="#" class="view-all">View All</a>
            </div>
            <div class="comic-grid">
                <div class="comic-card">
                    <div class="comic-thumb">
                        <img src="~/assets/solo-leveling.png" alt="Solo Leveling">
                    </div>
                    <div class="comic-info">
                        <h3>Solo Leveling</h3>
                        <p>Chapter 179</p>
                    </div>
                </div>
                <div class="comic-card">
