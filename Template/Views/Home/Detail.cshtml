<!-- Chapters Modal -->
<div id="chaptersModal" class="modal">
    <div class="modal-content">
        <span class="close-modal" id="closeChaptersModal">&times;</span>
        <div class="modal-header">
            <h2>All Chapters</h2>
        </div>
        <div class="modal-chapters-list">
            <a asp-action="Read" class="chapter-item">
                <span class="chapter-name">Chapter 179</span>
                <span class="chapter-time">2 hours ago</span>
            </a>
            <div class="chapter-item">
                <span class="chapter-name">Chapter 178</span>
                <span class="chapter-time">1 day ago</span>
            </div>
            <div class="chapter-item">
                <span class="chapter-name">Chapter 177</span>
                <span class="chapter-time">1 day ago</span>
            </div>
            <div class="chapter-item">
                <span class="chapter-name">Chapter 176</span>
                <span class="chapter-time">1 day ago</span>
            </div>
            <div class="chapter-item">
                <span class="chapter-name">Chapter 175</span>
                <span class="chapter-time">1 day ago</span>
            </div>
            <div class="chapter-item">
                <span class="chapter-name">Chapter 174</span>
                <span class="chapter-time">1 day ago</span>
            </div>
            <div class="chapter-item">
                <span class="chapter-name">Chapter 173</span>
                <span class="chapter-time">1 day ago</span>
            </div>
            <div class="chapter-item">
                <span class="chapter-name">Chapter 172</span>
