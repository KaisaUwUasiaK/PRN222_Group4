@{
    ViewData["Title"] = "Reading";
}

<main>
    <div class="reading-container">
        <div class="comic-pages">
            <!-- Using placeholder images for demo -->
            <img src="https://images.unsplash.com/photo-1620336655055-088d06e36bf0?auto=format&fit=crop&q=80&w=800" alt="Page 1">
            <img src="https://images.unsplash.com/photo-1612036782180-6f0b6cd846fe?auto=format&fit=crop&q=80&w=800" alt="Page 2">
            <img src="https://images.unsplash.com/photo-1578632292335-df3abbb0d586?auto=format&fit=crop&q=80&w=800" alt="Page 3">
        </div>

        <div class="read-comments">
            <h3>Comments</h3>
            <div class="comment-input-area" style="margin-top: 20px;">
                <textarea placeholder="Write a comment..."></textarea>
                <button class="btn btn-primary" style="width: auto;">Post Comment</button>
            </div>

            <div class="comments-list">
                <div class="comment-card" style="padding: 16px;">
                    <div class="comment-header">
                        <div class="comment-avatar"></div>
                        <div class="comment-author-info">
                            <span class="comment-author">Comickingfan</span>
                            <span class="comment-meta">1 hr ago</span>
                        </div>
                    </div>
                    <p class="comment-text">This is sick! I can't wait for the next chapter. The art is simply insane.</p>
                </div>
            </div>

            <div class="pagination" style="margin-top: 20px; justify-content: flex-start;">
                <a href="#" class="page-link active">1</a>
                <a href="#" class="page-link"><i class="fa-solid fa-chevron-right"></i></a>
            </div>
        </div>

        <div class="read-nav-bar">
            <a asp-action="Detail" class="btn btn-secondary">Previous Chapter</a>
            <a href="#" class="btn btn-primary">Next Chapter</a>
        </div>
    </div>
</main>
