<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - ComicVerse</title>
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar">
            <div class="container container-nav">
                <a asp-area="" asp-controller="Home" asp-action="Index" class="logo">COMIC<span class="logo-accent">VERSE</span></a>
                <ul class="nav-links">
                    <li><a asp-area="" asp-controller="Home" asp-action="Index" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">Browse</a></li>
                    <li><a href="#">My Library</a></li>
                </ul>
                <div class="search-bar">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="text" placeholder="Search comics, authors...">
                </div>
                <div class="nav-auth">
                    <a href="#" class="btn-text">Sign In</a>
                    <a href="#" class="btn btn-outline">Sign Out</a>
                </div>
            </div>
        </nav>
    </header>

    @RenderBody()

    <footer class="footer">
        <div class="container footer-container">
            <div class="footer-brand">
                <a asp-area="" asp-controller="Home" asp-action="Index" class="logo">COMIC<span class="logo-accent">VERSE</span></a>
                <p>&copy; 2024 ComicVerse. All rights reserved.</p>
            </div>
            <div class="footer-links">
                <div class="footer-group">
                    <h3>RESOURCES</h3>
                    <ul>
                        <li><a href="#">Privacy Policy</a></li>
                        <li><a href="#">Terms of Service</a></li>
                    </ul>
                </div>
                <div class="footer-group">
                    <h3>SOCIAL</h3>
                    <ul>
                        <li><a href="#">Twitter</a></li>
                        <li><a href="#">Discord</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </footer>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
